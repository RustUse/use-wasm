{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo: fmt workspace",
            "type": "shell",
            "command": "cargo xfmt",
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo: check workspace",
            "type": "shell",
            "command": "cargo xcheck",
            "problemMatcher": "$rustc",
            "group": "build"
        },
        {
            "label": "cargo: test workspace",
            "type": "shell",
            "command": "cargo xtest",
            "problemMatcher": "$rustc",
            "group": "test"
        },
        {
            "label": "cargo: clippy workspace",
            "type": "shell",
            "command": "cargo xlint",
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo: test minimal workspace",
            "type": "shell",
            "command": "cargo xtest-minimal",
            "problemMatcher": "$rustc",
            "group": "test"
        },
        {
            "label": "cargo: build workspace",
            "type": "shell",
            "command": "cargo xbuild",
            "problemMatcher": "$rustc",
            "group": "build"
        },
        {
            "label": "cargo: check examples",
            "type": "shell",
            "command": "cargo xexamples",
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo: doc workspace",
            "type": "shell",
            "command": "cargo xdoc",
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo: deny workspace",
            "type": "shell",
            "command": "cargo xdeny",
            "problemMatcher": []
        },
        {
            "label": "cargo: dry-run focused publish",
            "type": "shell",
            "command": "make publish-dry-run-focused",
            "problemMatcher": "$rustc"
        },
        {
            "label": "cargo: dry-run facade publish",
            "type": "shell",
            "command": "make publish-dry-run-facade",
            "problemMatcher": "$rustc"
        }
    ]
}